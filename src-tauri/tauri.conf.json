{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MP3 Buddy",
  "version": "0.6.0",
  "identifier": "mp3-buddy",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:15688",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MP3 Buddy",
        "width": 680,
        "height": 520,
        "minWidth": 680,
        "minHeight": 440,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../browser-extension": "browser-extension"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["mp3buddy"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/MaximeSahuc/mp3-buddy/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY1M0I0QjhCMTBDRDhDQjkKUldTNWpNMFFpMHM3OVplekhQMFZST3RmckwzVkpZckpDNmZnZXNQeVFvbk43NmtGYjBWUkowNG0K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
