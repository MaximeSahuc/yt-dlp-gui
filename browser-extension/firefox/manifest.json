{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "version": "1.1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "mp3-buddy@maximesahuc.github.io",
      "strict_min_version": "115.0"
    }
  },
  "permissions": ["cookies", "activeTab", "contextMenus", "notifications"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.youtu.be/*",
    "*://*.bilibili.com/*",
    "*://*.b23.tv/*",
    "*://*.twitch.tv/*",
    "*://*.vimeo.com/*",
    "*://*.dailymotion.com/*",
    "*://*.nicovideo.jp/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://*.instagram.com/*",
    "*://*.tiktok.com/*",
    "*://*.facebook.com/*",
    "*://*.fb.watch/*",
    "*://*.reddit.com/*",
    "*://*.soundcloud.com/*",
    "*://*.bandcamp.com/*",
    "*://*.crunchyroll.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_extName__",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
